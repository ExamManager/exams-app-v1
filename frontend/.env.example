# Shared API base for Stripe / email / auth helpers.
# Local Express: http://localhost:3001
# Vercel multi-service (rewrites /api → backend): /api
VITE_API_URL=http://localhost:3001

# Supabase (browser-safe anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional Stripe publishable key if used in the client
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx
